# MAA SITA INT UDHYOG — Environment Variables

# ============================================================
# SERVER-SIDE SECRETS — Never expose to browser, never commit
# ============================================================

# Supabase project URL (required in production)
SUPABASE_URL=

# Supabase service-role key — server only (required in production)
# Never use the anon key here; never send this to the browser
SUPABASE_SERVICE_ROLE_KEY=

# HMAC secret for pseudonymous client identity derivation
# MANDATORY in production. Never auto-generated in production.
# Fail-closed on missing. Must be a high-entropy random string (min 32 chars).
# Dev/test: use an explicitly documented temporary value (see README).
IP_HASH_SECRET=

# Cloudflare Turnstile — server secret key (required in production)
# Production: fail-closed if missing. Dev: set BOT_PROTECTION_MODE instead.
TURNSTILE_SECRET_KEY=

# Resend API key for email notifications (optional)
# If absent: submissions persist to DB but no email is sent. No error is raised.
RESEND_API_KEY=

# Comma-separated list of allowed CORS origins (production)
# Example: https://maasitaudhyog.com,https://www.maasitaudhyog.com
ALLOWED_ORIGINS=

# Comma-separated list of allowed CORS origins for preview deployments
# Never auto-trust *.vercel.app. Set explicit preview URLs.
PREVIEW_ALLOWED_ORIGINS=

# Email to notify on new contact/quote submissions (used with Resend)
NOTIFICATION_EMAIL=

# ============================================================
# DEVELOPMENT-ONLY OVERRIDES
# Never set these in production. They are checked against
# isProductionEnvironment() and will throw if set in prod.
# ============================================================

# Skip Turnstile server verification in development only
# BOT_PROTECTION_MODE=development_bypass

# Use in-memory rate limiting instead of Supabase in development only
# RATE_LIMIT_MODE=development_passthrough

# ============================================================
# CLIENT-SIDE (VITE_ prefix — safe to expose in browser bundle)
# ============================================================

# Public site URL (used for canonical URLs, OG metadata)
VITE_SITE_URL=https://maasitaudhyog.com

# Cloudflare Turnstile site key (public — OK to expose)
VITE_TURNSTILE_SITE_KEY=
