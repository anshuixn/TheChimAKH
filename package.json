{
  "name": "maa-sita-int-udhyog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vercel dev --listen 5174",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.api.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "generate:manifest": "node scripts/generate-frame-manifest.mjs",
    "validate:frames": "node scripts/validate-frame-sequence.mjs",
    "check:placeholders": "node scripts/check-placeholders.mjs",
    "verify:production": "node scripts/verify-production.mjs && npm run validate:frames && npm run check:placeholders && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.2",
    "gsap": "3.15.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/node": "5.8.23",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "msw": "2.15.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vercel": "55.0.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
